# ─── Environment Variables ─────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
# Keep the template — it has no secrets
!.env.example

# ─── Internal Docs (Assignment & Planning Files) ────────────────────────────────
docs/Real.md
docs/PHASES.md
docs/PROJECT.md
# Keep test_cases/ — they are the live demo files
!docs/test_cases/

# ─── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── TypeScript Build Output ───────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Next.js ───────────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/

# ─── OS & Editor Artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Test Coverage ─────────────────────────────────────────────────────────────
coverage/
.vitest/

# ─── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml and Dockerfiles — they are needed for build
# Ignore generated docker volumes if any
.docker-volumes/

# ─── Temporary & Misc ──────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
