# Normalize line endings for all text files to LF on commit
* text=auto eol=lf

# Explicitly handle specific file types
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env*  text eol=lf

# Binary files — never convert
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
